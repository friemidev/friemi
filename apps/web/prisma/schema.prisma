generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ActivityType {
  PUBLIC_EVENT
  USER_HOSTED
  LOCAL
  TRIP
}

enum ActivityCategory {
  FOOD
  WANDER
  AUDIO_VISUAL
  ART
  BOARD_GAME
  GROWTH
  TRAVEL
  MUSIC
  SPORTS
  OTHER
}

enum PriceType {
  FREE
  AA
  FIXED
  RANGE
}

enum ActivityStatus {
  OPEN
  FULL
  DRAFT
  RECRUITING
  CONFIRMED
  ENDED
  CANCELLED
}

enum ActivityVisibility {
  PUBLIC
  LINK_ONLY
  PRIVATE
}

enum PublicEventStatus {
  SCHEDULED
  CANCELLED
}

enum ParticipantStatus {
  JOINED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum UserProfileStatus {
  ACTIVE
  DELETED
}

enum UserRole {
  USER
  ADMIN
}

enum TrustScoreEventType {
  ACTIVITY_CHECK_IN
  INVITE_FRIEND
  PHONE_VERIFIED
  CLEAN_HALF_YEAR
  NO_SHOW
  USER_REPORT
  MASS_REPORT
  HARASSMENT_DM
  ORGANIZER_REPORT
}

enum MobilePlatform {
  ANDROID
  IOS
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum CommentType {
  QUESTION
  SUGGESTION
  REVIEW
}

enum NotificationType {
  PARTICIPATION_PENDING
  PARTICIPATION_CONFIRMED
  PARTICIPATION_CANCELLED
  PARTICIPATION_APPROVED
  PARTICIPATION_REJECTED
  ACTIVITY_UPDATED
  ACTIVITY_CANCELLED
  ACTIVITY_ANNOUNCEMENT
  FRIEND_REQUEST
  ACTIVITY_COMMENTED
  COMMENT_REPLY
  DIRECT_MESSAGE
  MOMENT_LIKED
  MOMENT_COMMENTED
  MOMENT_COMMENT_REPLY
  MOMENT_REPOSTED
  REPORT_CREATED
}

enum ReportTargetType {
  USER_PROFILE
  PUBLIC_EVENT
  ACTIVITY
  COMMENT
  MOMENT
  MOMENT_COMMENT
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  MISLEADING_INFORMATION
  SAFETY_CONCERN
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum MomentVisibility {
  FRIENDS
  PUBLIC
}

enum PlanetVisibility {
  PUBLIC
  PRIVATE
}

enum PlanetMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum GameToolKind {
  AVALON
  STORYTELLER
  WEREWOLF
}

enum GameToolRoomStatus {
  LOBBY
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum GameToolSubmissionKind {
  TEAM_VOTE
  MISSION_CARD
  ASSASSINATION_TARGET
}

model UserProfile {
  id                     String                     @id @default(cuid())
  clerkUserId            String                     @unique
  email                  String?
  emailVerifiedAt        DateTime?
  contactEmail           String?
  normalizedContactEmail String?
  phone                  String?
  normalizedPhone        String?
  friendCode             String?                    @unique @db.Char(6)
  nickname               String
  firstName              String?
  lastName               String?
  username               String?
  wechatId               String?
  normalizedWechatId     String?
  avatarUrl              String?
  bio                    String?
  interests              String[]                   @default([])
  status                 UserProfileStatus          @default(ACTIVE)
  role                   UserRole                   @default(USER)
  isCoCreator            Boolean                    @default(false)
  lastSignInAt           DateTime?
  clerkCreatedAt         DateTime?
  clerkUpdatedAt         DateTime?
  clerkDeletedAt         DateTime?
  syncedAt               DateTime?
  activities             Activity[]                 @relation("ActivityOrganizer")
  managedActivities      ActivityCoManager[]        @relation("ActivityCoManagerProfile")
  addedCoManagers        ActivityCoManager[]        @relation("ActivityCoManagerAddedBy")
  activityManagementLogs ActivityManagementLog[]    @relation("ActivityManagementLogActor")
  participations         ActivityParticipant[]
  guestParticipations    GuestActivityParticipant[] @relation("GuestLinkedUser")
  comments               Comment[]
  moments                Moment[]                   @relation("MomentAuthor")
  momentLikes            MomentLike[]               @relation("MomentLikeUser")
  momentComments         MomentComment[]            @relation("MomentCommentAuthor")
  notifications          Notification[]             @relation("NotificationRecipient")
  sentNotifications      Notification[]             @relation("NotificationActor")
  favoriteActivities     ActivityFavorite[]
  following              UserFollow[]               @relation("UserFollowing")
  followers              UserFollow[]               @relation("UserFollowers")
  sentFriendRequests     FriendRequest[]            @relation("FriendRequestRequester")
  receivedFriendRequests FriendRequest[]            @relation("FriendRequestReceiver")
  friendshipsAsUserA     Friendship[]               @relation("FriendshipUserA")
  friendshipsAsUserB     Friendship[]               @relation("FriendshipUserB")
  conversationsAsUserA   Conversation[]             @relation("ConversationUserA")
  conversationsAsUserB   Conversation[]             @relation("ConversationUserB")
  sentDirectMessages     DirectMessage[]            @relation("DirectMessageSender")
  authoredAnnouncements  ActivityAnnouncement[]     @relation("ActivityAnnouncementAuthor")
  submittedReports       Report[]                   @relation("ReportReporter")
  reviewedReports        Report[]                   @relation("ReportReviewer")
  mobileDevices          MobileDevice[]
  trustScoreEvents       TrustScoreEvent[]
  hostedGameToolRooms    GameToolRoom[]             @relation("GameToolRoomHost")
  gameToolRoomMembers    GameToolRoomMember[]       @relation("GameToolRoomMemberProfile")
  gameToolSeats          GameToolSeat[]             @relation("GameToolSeatProfile")
  reviewedCheckIns       ActivityParticipant[]      @relation("ActivityCheckInReviewer")
  gameToolEvents         GameToolEvent[]            @relation("GameToolEventActor")
  gameToolSubmissions    GameToolSubmission[]       @relation("GameToolSubmissionProfile")
  gameToolPlayerRecords  GameToolPlayerRecord[]     @relation("GameToolPlayerRecordProfile")
  ownedPlanets           Planet[]                   @relation("PlanetOwner")
  planetMemberships      PlanetMember[]
  planetMessages         PlanetMessage[]            @relation("PlanetMessageAuthor")
  planetMoments          PlanetMoment[]             @relation("PlanetMomentAuthor")
  planetMomentComments   PlanetMomentComment[]      @relation("PlanetMomentCommentAuthor")
  planetMomentLikes      PlanetMomentLike[]         @relation("PlanetMomentLikeProfile")
  planetCommentLikes     PlanetMomentCommentLike[]  @relation("PlanetCommentLikeProfile")
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  publicEventFavorites   PublicEventFavorite[]

  @@index([nickname])
  @@index([normalizedContactEmail])
  @@index([normalizedPhone])
  @@index([normalizedWechatId])
  @@index([isCoCreator, status])
  @@index([role, status])
}

model Planet {
  id               String           @id @default(cuid())
  slug             String           @unique
  inviteCode       String           @unique @db.VarChar(16)
  name             String
  nameTranslations Json?
  description      String?          @db.Text
  coverImageUrl    String?
  tags             String[]         @default([])
  visibility       PlanetVisibility @default(PUBLIC)
  ownerId          String
  owner            UserProfile      @relation("PlanetOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members          PlanetMember[]
  messages         PlanetMessage[]
  moments          PlanetMoment[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([visibility, createdAt])
  @@index([ownerId, createdAt])
}

model PlanetMember {
  id        String           @id @default(cuid())
  planetId  String
  profileId String
  role      PlanetMemberRole @default(MEMBER)
  planet    Planet           @relation(fields: [planetId], references: [id], onDelete: Cascade)
  profile   UserProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  joinedAt  DateTime         @default(now())

  @@unique([planetId, profileId])
  @@index([profileId, joinedAt])
}

model PlanetMessage {
  id        String      @id @default(cuid())
  planetId  String
  authorId  String
  content   String      @db.Text
  planet    Planet      @relation(fields: [planetId], references: [id], onDelete: Cascade)
  author    UserProfile @relation("PlanetMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([planetId, createdAt])
  @@index([authorId, createdAt])
}

model PlanetMoment {
  id        String                @id @default(cuid())
  planetId  String
  authorId  String
  content   String                @db.Text
  imageUrls String[]              @default([])
  planet    Planet                @relation(fields: [planetId], references: [id], onDelete: Cascade)
  author    UserProfile           @relation("PlanetMomentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments  PlanetMomentComment[]
  likes     PlanetMomentLike[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([planetId, createdAt])
  @@index([authorId, createdAt])
}

model PlanetMomentComment {
  id        String                    @id @default(cuid())
  momentId  String
  authorId  String
  content   String                    @db.Text
  moment    PlanetMoment              @relation(fields: [momentId], references: [id], onDelete: Cascade)
  author    UserProfile               @relation("PlanetMomentCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  likes     PlanetMomentCommentLike[]
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@index([momentId, createdAt])
  @@index([authorId, createdAt])
}

model PlanetMomentLike {
  id        String       @id @default(cuid())
  momentId  String
  profileId String
  moment    PlanetMoment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  profile   UserProfile  @relation("PlanetMomentLikeProfile", fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([momentId, profileId])
  @@index([profileId, createdAt])
}

model PlanetMomentCommentLike {
  id        String              @id @default(cuid())
  commentId String
  profileId String
  comment   PlanetMomentComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  profile   UserProfile         @relation("PlanetCommentLikeProfile", fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())

  @@unique([commentId, profileId])
  @@index([profileId, createdAt])
}

model MobileDevice {
  id            String         @id @default(cuid())
  userProfileId String
  userProfile   UserProfile    @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  platform      MobilePlatform
  fcmToken      String         @unique
  deviceId      String?
  appVersion    String?
  locale        String?
  timezone      String?
  userAgent     String?
  lastSeenAt    DateTime       @default(now())
  disabledAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userProfileId, disabledAt, lastSeenAt])
  @@index([platform, deviceId])
}

model Activity {
  id                String                     @id @default(cuid())
  title             String
  description       String
  itinerary         String?
  type              ActivityType               @default(LOCAL)
  category          ActivityCategory           @default(OTHER)
  city              String                     @default("Paris")
  destination       String?
  address           String
  latitude          Float?
  longitude         Float?
  startAt           DateTime
  endAt             DateTime?
  capacity          Int
  minParticipants   Int?
  requiresApproval  Boolean                    @default(false)
  priceType         PriceType                  @default(FREE)
  priceText         String
  coverImageUrl     String?
  ticketUrl         String?
  ticketLabel       String?
  source            String?
  sourceUrl         String?                    @unique
  externalSource    String?
  externalId        String?
  externalUrl       String?
  sourcePayload     Json?
  importedAt        DateTime?
  status            ActivityStatus             @default(RECRUITING)
  visibility        ActivityVisibility         @default(PUBLIC)
  shareEnabled      Boolean                    @default(false)
  shareToken        String?                    @unique
  organizerId       String
  organizer         UserProfile                @relation("ActivityOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  publicEventId     String?
  publicEvent       PublicEvent?               @relation(fields: [publicEventId], references: [id], onDelete: SetNull)
  merchantId        String?
  merchant          Merchant?                  @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  participants      ActivityParticipant[]
  guestParticipants GuestActivityParticipant[]
  comments          Comment[]
  notifications     Notification[]
  sourceLinks       ActivitySourceLink[]
  favorites         ActivityFavorite[]
  coManagers        ActivityCoManager[]
  managementLogs    ActivityManagementLog[]
  directMessages    DirectMessage[]
  announcements     ActivityAnnouncement[]
  trustScoreEvents  TrustScoreEvent[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([city, startAt])
  @@index([city, latitude, longitude])
  @@index([organizerId])
  @@index([publicEventId, status, startAt])
  @@index([merchantId])
  @@index([source])
  @@index([externalSource, externalId])
  @@index([externalUrl])
  @@index([ticketUrl])
  @@index([importedAt])
}

model ActivityCoManager {
  id               String       @id @default(cuid())
  activityId       String
  managerProfileId String
  addedByProfileId String?
  activity         Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  manager          UserProfile  @relation("ActivityCoManagerProfile", fields: [managerProfileId], references: [id], onDelete: Cascade)
  addedBy          UserProfile? @relation("ActivityCoManagerAddedBy", fields: [addedByProfileId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())

  @@unique([activityId, managerProfileId])
  @@index([managerProfileId])
  @@index([addedByProfileId])
}

model ActivityManagementLog {
  id         String       @id @default(cuid())
  activityId String
  actorId    String?
  action     String
  metadata   Json?
  activity   Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  actor      UserProfile? @relation("ActivityManagementLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime     @default(now())

  @@index([activityId, createdAt])
  @@index([actorId, createdAt])
}

model PublicEvent {
  id             String                @id @default(cuid())
  title          String
  description    String
  category       ActivityCategory      @default(OTHER)
  city           String                @default("Paris")
  address        String
  latitude       Float?
  longitude      Float?
  startAt        DateTime
  endAt          DateTime?
  priceType      PriceType             @default(FREE)
  priceText      String?
  coverImageUrl  String?
  officialUrl    String?
  ticketUrl      String?
  ticketLabel    String?
  status         PublicEventStatus     @default(SCHEDULED)
  visibility     ActivityVisibility    @default(PUBLIC)
  source         String?
  sourceUrl      String?               @unique
  externalSource String?
  externalId     String?
  externalUrl    String?
  sourcePayload  Json?
  importedAt     DateTime?
  lastSyncedAt   DateTime?
  teams          Activity[]
  favorites      PublicEventFavorite[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([city, startAt])
  @@index([status, startAt])
  @@index([visibility, startAt])
  @@index([externalSource, externalId])
  @@index([externalUrl])
  @@index([ticketUrl])
  @@index([importedAt])
}

model Merchant {
  id             String     @id @default(cuid())
  slug           String     @unique
  name           String
  description    String
  logoUrl        String?
  city           String     @default("Paris")
  address        String?
  latitude       Float?
  longitude      Float?
  websiteUrl     String?
  contactEmail   String?
  externalSource String?
  externalId     String?
  externalUrl    String?
  sourcePayload  Json?
  importedAt     DateTime?
  isActive       Boolean    @default(true)
  activities     Activity[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([isActive, city])
  @@index([externalSource, externalId])
  @@index([externalUrl])
  @@index([importedAt])
}

model ActivitySourceLink {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  source     String
  sourceUrl  String   @unique
  createdAt  DateTime @default(now())

  @@index([activityId])
}

model ActivityParticipant {
  id                  String                    @id @default(cuid())
  activityId          String
  userProfileId       String
  status              ParticipantStatus         @default(APPROVED)
  message             String?
  joinedAt            DateTime                  @default(now())
  cancelledAt         DateTime?
  checkInRequestedAt  DateTime?
  checkedInAt         DateTime?
  checkInCancelledAt  DateTime?
  checkInReviewedById String?
  activity            Activity                  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userProfile         UserProfile               @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  checkInReviewer     UserProfile?              @relation("ActivityCheckInReviewer", fields: [checkInReviewedById], references: [id], onDelete: SetNull)
  guestParticipant    GuestActivityParticipant? @relation("GuestLinkedParticipant")
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@unique([activityId, userProfileId])
  @@index([userProfileId])
  @@index([checkInReviewedById])
}

model TrustScoreEvent {
  id         String              @id @default(cuid())
  profileId  String
  profile    UserProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type       TrustScoreEventType
  delta      Int
  activityId String?
  activity   Activity?           @relation(fields: [activityId], references: [id], onDelete: SetNull)
  note       String?
  createdAt  DateTime            @default(now())

  @@unique([profileId, type, activityId])
  @@index([profileId, createdAt])
  @@index([activityId])
}

model GuestActivityParticipant {
  id                  String               @id @default(cuid())
  activityId          String
  activity            Activity             @relation(fields: [activityId], references: [id], onDelete: Cascade)
  displayName         String
  phone               String?
  normalizedPhone     String?
  email               String?
  normalizedEmail     String?
  wechatId            String?
  normalizedWechatId  String?
  message             String?
  status              ParticipantStatus    @default(APPROVED)
  sourceLocale        String?
  sourceUserAgent     String?
  sourceFingerprint   String?
  joinedAt            DateTime             @default(now())
  cancelledAt         DateTime?
  linkedAt            DateTime?
  linkedUserProfileId String?
  linkedUserProfile   UserProfile?         @relation("GuestLinkedUser", fields: [linkedUserProfileId], references: [id], onDelete: SetNull)
  linkedParticipantId String?              @unique
  linkedParticipant   ActivityParticipant? @relation("GuestLinkedParticipant", fields: [linkedParticipantId], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([activityId, normalizedEmail])
  @@unique([activityId, normalizedPhone])
  @@unique([activityId, normalizedWechatId])
  @@index([activityId, status])
  @@index([linkedUserProfileId])
  @@index([normalizedEmail])
  @@index([normalizedWechatId])
  @@index([sourceFingerprint, createdAt])
}

model ActivityFavorite {
  id            String      @id @default(cuid())
  activityId    String
  userProfileId String
  activity      Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([activityId, userProfileId])
  @@index([userProfileId, createdAt])
}

model PublicEventFavorite {
  id            String      @id @default(cuid())
  publicEventId String
  userProfileId String
  publicEvent   PublicEvent @relation(fields: [publicEventId], references: [id], onDelete: Cascade)
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([publicEventId, userProfileId])
  @@index([userProfileId, createdAt])
}

model Comment {
  id                String      @id @default(cuid())
  activityId        String
  authorId          String
  parentId          String?
  type              CommentType @default(QUESTION)
  content           String
  pinnedByOrganizer Boolean     @default(false)
  activity          Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  author            UserProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent            Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies           Comment[]   @relation("CommentReplies")
  deletedAt         DateTime?
  editedAt          DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([activityId, pinnedByOrganizer, createdAt])
  @@index([activityId, parentId, createdAt])
  @@index([authorId])
  @@index([parentId])
}

model Moment {
  id               String           @id @default(cuid())
  authorId         String
  content          String?          @db.Text
  visibility       MomentVisibility @default(FRIENDS)
  likeCount        Int              @default(0)
  commentCount     Int              @default(0)
  repostCount      Int              @default(0)
  resharedMomentId String?
  deletedAt        DateTime?
  author           UserProfile      @relation("MomentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  resharedMoment   Moment?          @relation("MomentReshares", fields: [resharedMomentId], references: [id], onDelete: SetNull)
  reshares         Moment[]         @relation("MomentReshares")
  images           MomentImage[]
  likes            MomentLike[]
  comments         MomentComment[]
  notifications    Notification[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([authorId, createdAt])
  @@index([visibility, createdAt])
  @@index([deletedAt, createdAt])
  @@index([resharedMomentId, createdAt])
}

model MomentImage {
  id        String   @id @default(cuid())
  momentId  String
  url       String
  width     Int?
  height    Int?
  sortOrder Int      @default(0)
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([momentId, sortOrder])
}

model MomentLike {
  id        String      @id @default(cuid())
  momentId  String
  userId    String
  moment    Moment      @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user      UserProfile @relation("MomentLikeUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([momentId, userId])
  @@index([userId, createdAt])
  @@index([momentId, createdAt])
}

model MomentComment {
  id            String          @id @default(cuid())
  momentId      String
  authorId      String
  parentId      String?
  content       String          @db.Text
  deletedAt     DateTime?
  editedAt      DateTime?
  moment        Moment          @relation(fields: [momentId], references: [id], onDelete: Cascade)
  author        UserProfile     @relation("MomentCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent        MomentComment?  @relation("MomentCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       MomentComment[] @relation("MomentCommentReplies")
  notifications Notification[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([momentId, parentId, createdAt])
  @@index([authorId, createdAt])
  @@index([parentId])
}

model ContentTranslation {
  id                   String   @id @default(cuid())
  entityType           String
  entityId             String
  field                String
  locale               String
  sourceHash           String
  sourceText           String   @db.Text
  translatedText       String   @db.Text
  provider             String   @default("deepl")
  detectedSourceLocale String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([entityType, entityId, field, locale, sourceHash])
  @@index([entityType, entityId, locale])
  @@index([locale, createdAt])
}

model Notification {
  id                     String                @id @default(cuid())
  type                   NotificationType
  recipientId            String
  recipient              UserProfile           @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId                String?
  actor                  UserProfile?          @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  activityId             String?
  activity               Activity?             @relation(fields: [activityId], references: [id], onDelete: SetNull)
  activityAnnouncementId String?
  activityAnnouncement   ActivityAnnouncement? @relation(fields: [activityAnnouncementId], references: [id], onDelete: SetNull)
  momentId               String?
  moment                 Moment?               @relation(fields: [momentId], references: [id], onDelete: SetNull)
  momentCommentId        String?
  momentComment          MomentComment?        @relation(fields: [momentCommentId], references: [id], onDelete: SetNull)
  readAt                 DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([recipientId, readAt, createdAt])
  @@index([activityId])
  @@index([activityAnnouncementId])
  @@index([momentId])
  @@index([momentCommentId])
}

model ActivityAnnouncement {
  id            String         @id @default(cuid())
  activityId    String
  authorId      String
  content       String
  activity      Activity       @relation(fields: [activityId], references: [id], onDelete: Cascade)
  author        UserProfile    @relation("ActivityAnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([activityId, createdAt])
  @@index([authorId, createdAt])
}

model Report {
  id          String           @id @default(cuid())
  reporterId  String
  reporter    UserProfile      @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType  ReportTargetType
  targetId    String
  reason      ReportReason
  description String?
  status      ReportStatus     @default(PENDING)
  reviewerId  String?
  reviewer    UserProfile?     @relation("ReportReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([reporterId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([reporterId, createdAt])
  @@index([reviewerId])
}

model UserFollow {
  id          String      @id @default(cuid())
  followerId  String
  followingId String
  follower    UserProfile @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   UserProfile @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

model FriendRequest {
  id             String              @id @default(cuid())
  requesterId    String
  receiverId     String
  pendingPairKey String?             @unique
  status         FriendRequestStatus @default(PENDING)
  message        String?
  requester      UserProfile         @relation("FriendRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver       UserProfile         @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  respondedAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([requesterId, status, createdAt])
  @@index([receiverId, status, createdAt])
  @@index([requesterId, receiverId, status])
}

model Friendship {
  id        String      @id @default(cuid())
  userAId   String
  userBId   String
  userA     UserProfile @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     UserProfile @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userAId, userBId])
  @@index([userBId])
}

model Conversation {
  id            String          @id @default(cuid())
  userAId       String
  userBId       String
  userA         UserProfile     @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB         UserProfile     @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages      DirectMessage[]
  lastMessageAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
  @@index([lastMessageAt])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  activityId     String?
  body           String
  imageUrls      String[]     @default([])
  readAt         DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         UserProfile  @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  activity       Activity?    @relation(fields: [activityId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([activityId])
}

model AnalyticsEvent {
  id            String   @id @default(cuid())
  name          String
  environment   String
  userProfileId String?
  anonymousId   String?
  sessionId     String?
  locale        String
  route         String
  referrer      String?
  userAgent     String?
  deviceType    String?
  sourceSurface String?
  entityType    String?
  entityId      String?
  appVersion    String?
  properties    Json?
  createdAt     DateTime @default(now())

  @@index([name, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([userProfileId, createdAt])
  @@index([sourceSurface, createdAt])
  @@index([environment, createdAt])
}

model GameToolRoom {
  id            String                 @id @default(cuid())
  kind          GameToolKind           @default(AVALON)
  status        GameToolRoomStatus     @default(LOBBY)
  code          String                 @unique @db.VarChar(8)
  locale        String                 @default("zh-CN")
  title         String
  mode          String                 @default("identity")
  playerCount   Int                    @default(7)
  hostId        String
  host          UserProfile            @relation("GameToolRoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  config        Json?
  state         Json?
  startedAt     DateTime?
  finishedAt    DateTime?
  cancelledAt   DateTime?
  seats         GameToolSeat[]
  members       GameToolRoomMember[]
  events        GameToolEvent[]
  submissions   GameToolSubmission[]
  playerRecords GameToolPlayerRecord[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([hostId, createdAt])
  @@index([kind, status, updatedAt])
  @@index([code])
}

model GameToolRoomMember {
  id           String        @id @default(cuid())
  roomId       String
  room         GameToolRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  profileId    String?
  profile      UserProfile?  @relation("GameToolRoomMemberProfile", fields: [profileId], references: [id], onDelete: SetNull)
  guestName    String?
  memberToken  String        @unique @db.VarChar(32)
  seatedSeatId String?
  seatedSeat   GameToolSeat? @relation("GameToolRoomMemberSeat", fields: [seatedSeatId], references: [id], onDelete: SetNull)
  readyAt      DateTime?
  lastSeenAt   DateTime      @default(now())
  leftAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([roomId, profileId])
  @@unique([seatedSeatId])
  @@index([roomId, lastSeenAt])
  @@index([profileId])
}

model GameToolSeat {
  id             String               @id @default(cuid())
  roomId         String
  profileId      String?
  privateToken   String               @unique @db.VarChar(32)
  seatNumber     Int
  displayName    String
  guestName      String?
  roleKey        String?
  roleAlignment  String?
  privatePayload Json?
  readyAt        DateTime?
  joinedAt       DateTime             @default(now())
  leftAt         DateTime?
  room           GameToolRoom         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomMember     GameToolRoomMember?  @relation("GameToolRoomMemberSeat")
  profile        UserProfile?         @relation("GameToolSeatProfile", fields: [profileId], references: [id], onDelete: SetNull)
  submissions    GameToolSubmission[]

  @@unique([roomId, seatNumber])
  @@unique([roomId, profileId])
  @@index([profileId, joinedAt])
  @@index([roomId, readyAt])
}

model GameToolEvent {
  id        String       @id @default(cuid())
  roomId    String
  actorId   String?
  type      String
  payload   Json?
  room      GameToolRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  actor     UserProfile? @relation("GameToolEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())

  @@index([roomId, createdAt])
  @@index([actorId, createdAt])
  @@index([type, createdAt])
}

model GameToolSubmission {
  id          String                 @id @default(cuid())
  roomId      String
  seatId      String?
  profileId   String?
  roundIndex  Int                    @default(0)
  kind        GameToolSubmissionKind
  value       String
  metadata    Json?
  submittedAt DateTime               @default(now())
  room        GameToolRoom           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  seat        GameToolSeat?          @relation(fields: [seatId], references: [id], onDelete: SetNull)
  profile     UserProfile?           @relation("GameToolSubmissionProfile", fields: [profileId], references: [id], onDelete: SetNull)

  @@unique([roomId, roundIndex, kind, seatId])
  @@index([roomId, kind, roundIndex])
  @@index([profileId, submittedAt])
}

model GameToolPlayerRecord {
  id            String       @id @default(cuid())
  roomId        String
  profileId     String
  kind          GameToolKind
  variantKey    String?
  variantName   String?
  seatNumber    Int?
  roleKey       String?
  roleAlignment String?
  result        String?
  isJudge       Boolean      @default(false)
  playedAt      DateTime     @default(now())
  metadata      Json?
  room          GameToolRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  profile       UserProfile  @relation("GameToolPlayerRecordProfile", fields: [profileId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([roomId, profileId])
  @@index([profileId, kind, playedAt])
  @@index([roomId])
}
